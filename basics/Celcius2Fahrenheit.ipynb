     "text": [
      "Enter a value which you want to convert into Fahrenheit:  -1\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "30.2 F\n"
     ]
    }
   ],
   "source": [
    "user_input=float(input(\"Enter a value which you want to convert into Fahrenheit: \"))\n",
    "cel_to_far=(user_input* (9/5)) + 32\n",
    "\n",
    "print(cel_to_far,'F')"
   ]
